### Adam Optimizer

```python
import torch

def adam_optimizer(
    parameter: torch.Tensor,
    grad: torch.Tensor,
    m: torch.Tensor,
    v: torch.Tensor,
    t: int,
    learning_rate: float = 0.001,
    beta1: float = 0.9,
    beta2: float = 0.999,
    epsilon: float = 1e-8
):
		
    parameter = torch.as_tensor(parameter, dtype=torch.float64)
    grad = torch.as_tensor(grad, dtype=torch.float64)
    m = torch.as_tensor(m, dtype=torch.float64)
    v = torch.as_tensor(v, dtype=torch.float64)
    # Your code here
    m = beta_1 * m + (1 - beta_1) * gradient
    v = beta_2 * v + (1 - beta_2) * gradient**2
    m_hat = m / (1 -beta_1**t)
    v_hat = v / (1- beta_2**t)
    parameter = parameter - learning_rate * m_hat / torch.sqrt(v_t + epsilon) * gradient
    return torch.round(parameter, decimals=5), torch.round(m, decimals=5), torch.round(v, decimals=5)
```

