# Transformer Architectures

## Single Head Attention

```python
import torch
import torch.nn as nn
import torch.nn.functional as F

class AttentionHead(nn.Module):
		def __init__(self, d_model, d_v):
			super().__init__()
			self.d_model = d_model # model dimensions 
			self.d_v = d_v
			self.Q_W = nn.Linear(d_model, d_model, bias=False)
			self.Q_K = nn.Linear(d_model, d_model, bias=False)
			self.Q_V = nn.Linear(d_model, d_v, bias=False)
			self.device = "cuda" if cuda.mps.is_available() else "cpu"
		
		def forward(self, x, causal=False):
			q = self.Q_W(x) #create and obtain key, query, value vectors 
			k = self.Q_K(x)
			v = self.Q_V(x)
			scores = q @ k.transpose(-2, -1) / torch.sqrt(k.shape[-1]) # obtain the scores using formula.
			if causal: #causal attention 
				mask = torch.triu(torch.ones((k.shape[-1], k.shape[-1]), device=self.device, dtype=torch.float32), diagonal=1)
				# keeps upper triangle of matrix and zeroes out the lower triangle, but
				# diagonal = 1 does not keep the main diagonal.
				scores = scores.masked_fill(mask == 1, -float("inf"))
			softmax_value = F.softmax(scores, dim=-1)
			return softmax_value @ v
```

→ d_k is the length of the query and value vectors, and often equals `d_model`

→ d_v is the length of each value vector 

→ d_model is how dimensional a vector is and every layer reads that width and writes that width. 

- bias = False ****because the dot product will yield unnecessary positional information.

## Multi-head Attention

Second step to single head attention, implements several attention heads in a block.

```python
import torch
import torch.nn as nn
import torch.nn.functional as F

class MultiHeadAttention(nn.Module):
	def __init__(self, num_heads, d_model):
		self.d_heads = num_heads
		self.head_dim = num_heads // d_model
		self.d_model = d_model
		self.layers = nn.ModuleList([AttentionHead(self.head_dim) for _ in range(num_heads)
		self.device = "cuda" if torch.device.available() else "cpu"
		self.o_proj = nn.Linear(self.d_model, d_model, bias=False)
				
	def forward(self, x):
		res = []
		for layer in self.layers:
			res.append(layer(x))
		val = torch.cat(res, device=self.device)
		attn = self.o_proj(val)
		return attn
```

## Transformer Block

```python
import torch
import torch.nn as nn
import torch.nn.functional as F

class TransformerBlock(nn.Module):
	def __init__(self, num_heads, d_model):
		super().__init__()
		self.layer_norm_1 = nn.LayerNorm(d_model)
		self.layer_norm_2 = nn.LayerNorm(d_model)
		self.mlp = nn.Sequential(nn.Linear(d_model, 4*d_model),
															nn.ReLU(),
															nn.Linear(4*d_model, d_model))
		self.multiHeadAttention = MultiHeadAttention(num_heads, d_model)
		
	def forward(self, x):
		x = x + self.multiHeadAttention(self.layer_norm_1(x))
		x = x + self.mlp(self.layer_norm_2(x))
		return x
```

## Transformer

```python
import torch
import torch.nn as nn
import torch.nn.functional as F

class Transformer(nn.Module):
	def __init__(self, num_blocks, num_heads, d_model, d_vocab):
		super().__init__()
		self.num_blocks = num_blocks
		self.blocks = nn.ModuleList([TransformerBlock(num_heads, d_model) for _ in range(num_blocks)])
		self.embedding = nn.Embedding([d_vocab, d_model]) #takes in (num_embeddings, embedding_Dim)*
		self.output_layer = nn.Linear(d_model, d_vocab)
	
	def forward(self, x):
		#taking in token indices you need to do embedding
		x = self.embedding(x)
		for transformer_block in self.blocks:
			x = transformer_block(x)
		x = self.output_layer(x)
		return x #creating new blocks in forward means that 
		# there is no learning that takes place and those are randomly initialized.
```

- you need a moduleList because PyTorch tracks parameters in a moduleList and optimizer cannot update these weights.
- nn.Sequential / nn.ModuleList is required because then you would have only one block being used and only those parameters would be updated.
- Pytorch builds a tree that is then within nn.Module and then this goes through Transformer → TransformerBlock → MultiHeadAttention → AttentionHead
    - Then when you do loss.backward() it goes through the tree and computes.

